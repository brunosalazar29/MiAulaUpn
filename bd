DROP DATABASE IF EXISTS mi_aula_upn;
CREATE DATABASE mi_aula_upn;
USE mi_aula_upn;

-- 🏢 TABLA DE SEDES: define las diferentes ubicaciones de la universidad
CREATE TABLE sede (
    id_sede INT AUTO_INCREMENT PRIMARY KEY,
    nombre_sede VARCHAR(100) NOT NULL,
    fec_creacion DATETIME DEFAULT CURRENT_TIMESTAMP
);

-- 🏛️ TABLA DE PABELLONES: cada pabellón está en una sede
CREATE TABLE pabellon (
    id_pabellon INT AUTO_INCREMENT PRIMARY KEY,
    id_sede INT NOT NULL,
    letra_pabellon CHAR(1) NOT NULL,
    nro_pisos INT NOT NULL,
    fec_creacion DATETIME DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (id_sede) REFERENCES sede(id_sede)
);

-- 🚪 TABLA DE SALONES: cada salón está en un pabellón y sede
CREATE TABLE salones (
    id_salon INT AUTO_INCREMENT PRIMARY KEY,
    id_pabellon INT NOT NULL,
    id_sede INT NOT NULL,
    nro_salon VARCHAR(10) NOT NULL,
    fec_creacion DATETIME DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (id_pabellon) REFERENCES pabellon(id_pabellon),
    FOREIGN KEY (id_sede) REFERENCES sede(id_sede)
);
-- 1. Eliminar la tabla si ya existe
